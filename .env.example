# API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# NVIDIA NIMS
NVIDIA_NIMS_API_KEY=
NVIDIA_NIMS_API_BASE=https://integrate.api.nvidia.com/v1

# LiteLLM routing defaults
# Use provider-prefixed model IDs.
LITELLM_DEFAULT_MODEL=openrouter/meta-llama/llama-3.1-8b-instruct
LITELLM_STRONG_MODEL=nvidia_nim/meta/llama-3.1-70b-instruct

# Optional aliases (equivalent to LITELLM_* above)
WORKER_MODEL=
STRONG_MODEL=

# Retrieval providers
TAVILY_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# Runtime controls
MAX_ITERATIONS=4
MAX_RUNTIME_MINUTES=25
MAX_COST_USD=5.0
DEFAULT_TEMPLATE=ieee
