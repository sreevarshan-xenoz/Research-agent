# API providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# NVIDIA NIMS
NVIDIA_API_KEY=
NVIDIA_NIMS_API_KEY=
NVIDIA_NIMS_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=qwen/qwen3-coder-480b-a35b-instruct
ENABLE_NVIDIA_MODEL=false

# Model labels
# These are mostly informational unless an optional hosted model is enabled.
LITELLM_DEFAULT_MODEL=local/fallback-worker
LITELLM_STRONG_MODEL=local/fallback-strong

# Optional aliases (equivalent to LITELLM_* above)
WORKER_MODEL=
STRONG_MODEL=

# Retrieval providers
TAVILY_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
WEB_PROVIDER=duckduckgo
BROWSER_USE_API_KEY=
BROWSER_USE_MODEL=bu-2-0
BROWSER_USE_OPENAI_MODEL=
BROWSER_USE_DISABLE_EXTENSIONS=true

# Retrieval notes:
# - duckduckgo: free DuckDuckGo package-backed search path
# - scrape: free DuckDuckGo HTML scraping path
# - browser_use: SDK -> Playwright -> scraping fallback
# - hybrid: browser_use plus DuckDuckGo
PAPER_PROVIDERS=arxiv,semantic_scholar,openalex

# Runtime controls
MAX_ITERATIONS=4
MAX_RUNTIME_MINUTES=25
MAX_COST_USD=5.0
DEFAULT_TEMPLATE=ieee
